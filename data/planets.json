  "info": {
    "sun":     { "type": "Estrela",         "temp": "5.500 °C (superfície)", "period": "—",       "moons": 0,   "desc": "O coração do sistema solar. Contém 99,8% de toda a massa — o Sol domina gravitacionalmente tudo que orbita ao seu redor." },
    "mercury": { "type": "Planeta Rochoso", "temp": "−180 a +430 °C",       "period": "88 dias",  "moons": 0,   "desc": "O menor planeta e o mais próximo do Sol. Sem atmosfera para reter calor, sofre a maior variação térmica do sistema solar." },
    "venus":   { "type": "Planeta Rochoso", "temp": "470 °C (constante)",    "period": "225 dias", "moons": 0,   "desc": "Temperatura constante de 470 °C, suficiente para derreter chumbo. O efeito estufa mais extremo do sistema solar." },
    "earth":   { "type": "Planeta Rochoso", "temp": "−90 a +60 °C",         "period": "365 dias", "moons": 1,   "desc": "O único mundo com vida conhecida no universo. Toda a história da humanidade aconteceu neste único ponto azul pálido." },
    "mars":    { "type": "Planeta Rochoso", "temp": "−140 a +20 °C",        "period": "687 dias", "moons": 2,   "desc": "O Monte Olimpo tem 22 km de altitude — três vezes o Everest. Tempestades de areia podem cobrir o planeta inteiro por meses." },
    "jupiter": { "type": "Gigante Gasoso",  "temp": "−110 °C",              "period": "12 anos",  "moons": 95,  "desc": "Massa 2,5× maior que a soma de todos os outros planetas. A Grande Mancha Vermelha é uma tempestade ativa há mais de 350 anos." },
    "saturn":  { "type": "Gigante Gasoso",  "temp": "−140 °C",              "period": "29 anos",  "moons": 146, "desc": "Seus anéis têm 270.000 km de largura mas apenas 1 km de espessura. Tão leve que flutuaria em um oceano." },
    "uranus":  { "type": "Gigante de Gelo", "temp": "−195 °C",              "period": "84 anos",  "moons": 28,  "desc": "Gira completamente de lado, com eixo inclinado 98°. Provavelmente virado por um impacto colossal na sua formação." },
    "neptune": { "type": "Gigante de Gelo", "temp": "−200 °C",              "period": "165 anos", "moons": 16,  "desc": "Ventos de 2.100 km/h — os mais rápidos do sistema solar. Descoberto por cálculo matemático antes de ser visto." },
    "pluto":    { "type": "Planeta Anão",    "temp": "−230 °C",              "period": "248 anos", "moons": 5,   "desc": "Descoberto em 1930 e reclassificado como planeta anão em 2006. A luz do Sol leva 5,5 horas para chegar aqui." },
    "ceres":    { "type": "Planeta Anão",    "temp": "−110 °C",              "period": "4,6 anos", "moons": 0,   "desc": "O maior corpo do cinturão de asteroides, com 940 km de diâmetro. Descoberto em 1801, foi considerado planeta por décadas antes de ser reclassificado." },
    "haumea":   { "type": "Planeta Anão",    "temp": "−241 °C",              "period": "284 anos", "moons": 2,   "desc": "Gira tão rápido que tem forma de bola de rugby achatada. Seu dia dura apenas 3,9 horas — o menor entre os planetas anões." },
    "makemake": { "type": "Planeta Anão",    "temp": "−239 °C",              "period": "306 anos", "moons": 1,   "desc": "Descoberto em 2005, três dias após a Páscoa, foi apelidado de Easterbunny. Sua superfície avermelhada é coberta de metano congelado." },
    "eris":     { "type": "Planeta Anão",    "temp": "−243 °C",              "period": "557 anos", "moons": 1,   "desc": "Mais massivo que Plutão, sua descoberta em 2005 provocou o debate que rebaixou Plutão a planeta anão. A luz do Sol leva mais de 9 horas para chegar aqui." }
  }
